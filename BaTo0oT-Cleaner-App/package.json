{
  "name": "bato0ot-cleaner-app",
  "version": "3.0.0",
  "description": "BaTo0oT Cleaner - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.bato0ot.cleaner",
    "productName": "BaTo0oT Cleaner",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "publisherName": "BaTo0oT"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb", "snap"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "BaTo0oT Cleaner v3.0"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "systeminformation": "^5.22.11",
    "diskusage": "^1.2.0",
    "sudo-prompt": "^9.2.1",
    "node-fetch": "^2.7.0",
    "@supabase/supabase-js": "^2.43.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
