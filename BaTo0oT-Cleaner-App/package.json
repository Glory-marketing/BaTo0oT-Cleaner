{
  "name": "bato0ot-cleaner-app",
  "version": "3.0.0",
  "description": "BaTo0oT Cleaner - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.bato0ot.cleaner",
    "productName": "BaTo0oT Cleaner",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["portable"],
      "icon": null,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": ["dir"],
      "icon": null
    },
    "linux": {
      "target": ["dir"],
      "icon": null
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
